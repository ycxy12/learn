# ============================================================
# 环境变量配置模板
# 复制此文件为 .env，并填写真实值（.env 不提交到 git）
# ============================================================

# 数据库配置（MySQL）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=learn1_user
DB_PASS=your_password_here
DB_NAME=learn1_db

# JWT 密钥（请替换为随机长字符串）
JWT_SECRET=your_jwt_secret_here

# 服务端口
PORT=3000

# 前端地址，用于 CORS（开发时为 localhost，生产时改为实际域名或IP）
CLIENT_ORIGIN=http://localhost:5173
